# Cargo build artifacts
/target
# Alternate target dir for the MA57-linked build
/target-ma57

# mdbook render output — `make book` regenerates it from docs/src/.
/docs/book

# Local cargo config — holds a machine-specific CoinHSL rpath for the
# optional `ma57` feature. Set COINHSL_DIR instead (see crates/pounce-hsl).
/.cargo/config.toml

# Upstream Ipopt source mirror — tracked separately (vendor as submodule if desired)
/ref

# Benchmark suite — only the cutest harness source is tracked. Everything
# else is regenerated locally (large NL exports, compiled SIF .dylibs,
# per-run logs and JSON results).
/benchmarks/*
!/benchmarks/README.md
!/benchmarks/Makefile
!/benchmarks/benchmark_report.py
!/benchmarks/BENCHMARK_REPORT.md
!/benchmarks/BENCHMARK_REPORT.json
!/benchmarks/cutest
!/benchmarks/large_scale
!/benchmarks/scripts
!/benchmarks/*/
/benchmarks/*/*
!/benchmarks/*/README.md
!/benchmarks/scripts/*
# large_scale is a workspace member — its Cargo manifest and Rust
# sources must be tracked even though `/benchmarks/*/*` excludes them
# by default. Per-run results stay ignored.
!/benchmarks/large_scale/Cargo.toml
!/benchmarks/large_scale/build.rs
!/benchmarks/large_scale/src
!/benchmarks/large_scale/src/**
/benchmarks/cutest/problems/
/benchmarks/cutest/*.json
/benchmarks/cutest/*.jsonl
/benchmarks/cutest/*_stderr.txt
/benchmarks/cutest/*.stderr
/benchmarks/cutest/*.log
/benchmarks/cutest/*.csv
/benchmarks/cutest/CUTEST_REPORT*.md
/benchmarks/cutest/FERAL_DELTA*.md
/benchmarks/cutest/l1_audit/
/benchmarks/logs/

# Python cache
__pycache__/
*.pyc

# Python build artifacts (maturin develop emits the .so next to the package)
python/pounce/_pounce*.so
python/pounce/_pounce*.pyd
# Bundled CLI binary — staged here by the release workflow before
# `maturin build`, also written by local devs running `cargo build`
# into this dir. Never tracked.
python/pounce/bin/
python/.pytest_cache/
python/build/
python/dist/
python/*.egg-info/

# Claude Code local state
.claude/

# Crucible knowledge base — kept entirely local. The distilled sources
# include extracted text of copyrighted papers, so the whole directory
# stays out of version control.
.crucible/

# macOS
.DS_Store

# Editor
*.swp
*.swo
.idea/
.vscode/

# Local logo experiments
/logos/pounce_B_trajectory.png
/logos/pounce_C_cage_break.png

# GAMS link build artifacts
gams/libGamsPounce.dylib
gams/libGamsPounce.so
gams/*.lst
gams/*.log
gams/*.sol

# Vendored nlpbench clone is private (GAMS-licensed); keep the whole subtree
# out of version control, including any pounce-side reports/testsets/scripts
# parked inside it for convenience.
gams/nlpbench/
gams/nlpbench.zip

# AMPL .sol files written next to the .nl test fixtures when the CLI is
# run on them — generated output, not fixtures.
crates/pounce-cli/tests/fixtures/*.sol

# pyomo-pounce plugin build artifacts.
pyomo-pounce/build/
pyomo-pounce/pyomo_pounce.egg-info/

# Python build artifacts for studio packages.
/studio/**/__pycache__/
/studio/**/*.egg-info/
/studio/**/.pytest_cache/
/studio/**/.venv/
# maturin emits the native extension next to the package source
/studio/**/_native*.so
/studio/**/_native*.pyd
