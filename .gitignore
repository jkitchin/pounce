# Cargo build artifacts
/target
# Alternate target dir for the MA57-linked build
/target-ma57

# mdbook render output — `make book` regenerates it from docs/src/.
/docs/book

# Versioned-docs render output — `scripts/build-versioned-docs.sh` default
# output dir (stable + dev + archived tag builds for GitHub Pages).
/site
/_serve

# Local Python venv used to build/test the native extension
# (`maturin develop`). Machine-specific build artifact.
/.venv

# Local cargo config — holds a machine-specific CoinHSL rpath for the
# optional `ma57` feature. Set COINHSL_DIR instead (see crates/pounce-hsl).
/.cargo/config.toml

# Upstream Ipopt source mirror — tracked separately (vendor as submodule if desired)
/ref

# Benchmark suite — only the harness sources, per-suite READMEs, and the
# composite report are tracked. The .nl problem inputs and per-run outputs
# (logs, JSON results, .sol files) are regenerated locally.
/benchmarks/*
!/benchmarks/README.md
!/benchmarks/Makefile
!/benchmarks/benchmark_report.py
!/benchmarks/BENCHMARK_REPORT.md
!/benchmarks/BENCHMARK_REPORT.json
!/benchmarks/figures
!/benchmarks/figures/*
!/benchmarks/preprocessing
!/benchmarks/scripts
!/benchmarks/*/
/benchmarks/*/*
!/benchmarks/*/README.md
!/benchmarks/preprocessing/*
!/benchmarks/scripts/*
# The large_scale suite is now .nl-driven: its problems are emitted by a
# Pyomo generator rather than a compiled Rust crate. Track the generator
# (and README, via the rule above); the generated .nl and per-run results
# stay ignored like every other suite.
!/benchmarks/large_scale/generate_nl.py
# The qp (Maros-Meszaros convex QP) suite is likewise .nl-driven: its
# problems are downloaded as .mat from the qpsolvers mirror and converted
# to .nl by a Pyomo generator. Track the generator (and README +
# ipopt_ma57.json via the rules above); the downloaded .mat, generated
# .nl, and per-run results stay ignored like every other suite.
!/benchmarks/qp/generate_nl.py
# The lp suite is the small-LP validation set (Netlib + size-filtered
# Mészáros), and lpopt is the hard lpopt stress tier. Both fetch MPS and
# convert to .nl; track their generator + the MPS->nl converter so each is
# reproducible. Downloaded MPS, generated .nl, and per-run results stay
# ignored like every other suite.
!/benchmarks/lp/generate_nl.py
!/benchmarks/lp/mps_to_nl.py
!/benchmarks/lpopt/build_subset.py
!/benchmarks/lpopt/mps_to_nl.py
# The cblib suite is the conic (exp/power cone) tier: CBLIB .cbf instances
# solved through the pounce_cblib binary. Track its runner (README via the
# per-suite rule above); the per-run pounce.json stays ignored like every
# other suite.
!/benchmarks/cblib/run_cblib.py
# Vanderbei reference status (derived once from cute_table.pdf): which
# problems have a documented feasible optimum vs. are hard/infeasible/
# unbounded/untabulated. Tracked so we never have to re-derive it.
!/benchmarks/vanderbei/cute_table_status.json
!/benchmarks/vanderbei/cute_table_status.py
# The Ipopt-MA57 reference is decoupled from the per-release POUNCE run:
# it is generated once (`make ipopt-reference`) and committed so release
# reports compare against it without rerunning Ipopt. Per-suite reference
# files + the provenance stamp are tracked; the per-release pounce.json is
# not (regenerated every release).
!/benchmarks/*/ipopt_ma57.json
!/benchmarks/ipopt_ma57.provenance.json
/benchmarks/logs/

# Python cache
__pycache__/
*.pyc

# Python build artifacts (maturin develop emits the .so next to the package)
python/pounce/_pounce*.so
python/pounce/_pounce*.pyd
# Bundled CLI binary — staged here by the release workflow before
# `maturin build`, also written by local devs running `cargo build`
# into this dir. Never tracked.
python/pounce/bin/
python/.pytest_cache/
python/build/
python/dist/
# Figures rendered by example scripts (e.g. examples/critical_points.py)
python/examples/*.png
python/*.egg-info/

# Local virtualenvs (e.g. for building the extension + running notebooks)
.venv/

# Claude Code local state
.claude/

# Crucible knowledge base — kept entirely local. The distilled sources
# include extracted text of copyrighted papers, so the whole directory
# stays out of version control.
.crucible/

# Local research scratch — experiments, notes, drafts, downloaded
# papers. Never tracked; nothing under here ships with the repo.
/research/

# macOS
.DS_Store

# Editor
*.swp
*.swo
.idea/
.vscode/

# Local logo experiments
/logos/pounce_B_trajectory.png
/logos/pounce_C_cage_break.png

# GAMS link build artifacts
gams/libGamsPounce.dylib
gams/libGamsPounce.so
gams/*.lst
gams/*.log
gams/*.sol

# Vendored nlpbench clone is private (GAMS-licensed); keep the whole subtree
# out of version control, including any pounce-side reports/testsets/scripts
# parked inside it for convenience.
gams/nlpbench/
gams/nlpbench.zip

# AMPL .sol files written next to the .nl test fixtures when the CLI is
# run on them — generated output, not fixtures.
crates/pounce-cli/tests/fixtures/*.sol
crates/pounce-cli/tests/fixtures_issue_49/*.sol

# pyomo-pounce plugin build artifacts.
pyomo-pounce/build/
pyomo-pounce/pyomo_pounce.egg-info/

# Python build artifacts for studio packages.
/studio/**/__pycache__/
/studio/**/*.egg-info/
/studio/**/.pytest_cache/
/studio/**/.venv/
# maturin emits the native extension next to the package source
/studio/**/_native*.so
/studio/**/_native*.pyd
